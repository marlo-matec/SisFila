
{
  "name": "sisfila",
  "version": "2.2.0",
  "description": "Sistema de Gestão de Filas (SQLite Async)",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm run server\" \"wait-on http://localhost:3000 && vite\"",
    "build": "tsc && vite build",
    "server": "node server.js",
    "lint": "tsc --noEmit",
    "start": "npm run build && node server.js",
    "preview": "vite preview",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.matec.sisfila",
    "productName": "SisFila",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "server.js",
      "package.json",
      "SumatraPDF.exe"
    ],
    "asarUnpack": [
      "**/SumatraPDF.exe",
      "**/node_modules/sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.svg"
    }
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "sqlite3": "^5.1.7",
    "sqlite": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "idb": "^8.0.0",
    "lucide-react": "^0.344.0",
    "puppeteer": "^24.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "wait-on": "^7.2.0"
  }
}
